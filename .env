# Park Smart UK - Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── Google Maps API Key ───────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/
# Enable these APIs:
#   1. Maps JavaScript API        (map display, markers, info windows)
#   2. Street View Static API     (embedded street view)
#   3. Directions API             (embedded turn-by-turn routing)
#   4. Places API                 (autocomplete search, nearby search)
#   5. Geocoding API              (address to coordinates)
#   6. Maps JavaScript API - Visualization (heatmap overlay)
GOOGLE_MAPS_API_KEY=AIzaSyDcSH2hKnoTjIJaxBp0HwQhgXSiBIz0ThA

# ── Upload settings ───────────────────────────────────────────────────────────
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=static/images/uploads

# ── Tesseract OCR (Windows only) ──────────────────────────────────────────────
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Production DB ─────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/parksmart
